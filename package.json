{
  "name": "@gzkdev/compress",
  "version": "1.0.0",
  "description": "A lightning-fast, beautifully animated CLI image compressor that natively optimizes images using sharp.",
  "keywords": [
    "image",
    "compress",
    "cli",
    "ink",
    "sharp",
    "optimization"
  ],
  "homepage": "https://github.com/gzkdev/compressor#readme",
  "bugs": {
    "url": "https://github.com/gzkdev/compressor/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gzkdev/compressor.git"
  },
  "license": "ISC",
  "author": "gzkdev",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "main": "dist/cli.js",
  "types": "dist/cli.d.ts",
  "bin": {
    "compress": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "release": "pnpm build && changeset publish",
    "start": "node dist/cli.js",
    "lint": "eslint .",
    "format:write": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "log-symbols": "^7.0.1",
    "meow": "^14.1.0",
    "react": "^19.2.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "eslint": "^10.0.3",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "packageManager": "pnpm@10.28.1"
}
